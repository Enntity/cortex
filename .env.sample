AZURE_OAI_API_KEY=_______________________
APPTEK_API_KEY=""
APPTEK_API_ENDPOINT="https://api.apptek.com"

# GCS File Storage (required for file handler + gcsfuse)
GCS_BUCKET_NAME=cortex-files
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Workspace Backend (docker or hetzner)
WORKSPACE_BACKEND=docker
# WORKSPACE_IMAGE_VERSION=  # set to commit SHA for auto-reprovision
# WORKSPACE_IDLE_TIMEOUT_MS=1800000  # 30 min

# Hetzner (only if WORKSPACE_BACKEND=hetzner)
# HETZNER_API_TOKEN=
# HETZNER_LOCATION=fsn1
# HETZNER_SERVER_TYPE=cx42
# HETZNER_FIREWALL_ID=
# HETZNER_SSH_KEY_ID=
# HETZNER_PRIVATE_NETWORK_ID=